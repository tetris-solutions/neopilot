# NeoPilot configuration
# Copy to .env and fill in values

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOGLEVEL=INFO

# Debug mode — when enabled, API tool responses include the full
# request URL and raw response body for troubleshooting
NEOPILOT_DEBUG=0

# Optional: override default data directory (~/.neopilot/)
# NEOPILOT_DATA_DIR=/path/to/data
