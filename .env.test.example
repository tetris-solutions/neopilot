# Integration test credentials
# Copy this file to .env.test and fill in real values.
# .env.test is in .gitignore — it will NOT be committed.
#
# These credentials are used ONLY by tests/test_integration.py
# to validate that our models can parse real NeoDash API responses.
#
# You need access to at least one NeoDash instance.
# Ask your team lead for a test slug and API token.

NEODASH_TEST_SLUG=yourslug
NEODASH_TEST_TOKEN=your_api_token_here
